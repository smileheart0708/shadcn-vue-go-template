# Backend runtime
PORT=8080
DATA_DIR=.data
DB_NAME=data.db
API_REQUEST_LOG_ENABLED=false

# JWT secret
# Leave blank to auto-generate and persist one under DATA_DIR/.jwt_secret
JWT_SECRET=change-me-to-a-long-random-secret

# Session lifetimes
JWT_TTL=10m
REFRESH_IDLE_TTL=168h
REFRESH_ABSOLUTE_TTL=720h
REFRESH_COOKIE_NAME=

# Frontend dev mock toggle
VITE_API_MOCKING=false
